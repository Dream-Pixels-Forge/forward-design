# Google Drive Integration
# =============================================================================
# To set up Google Drive integration:
#
# 1. Go to https://console.cloud.google.com/ and create a new project
# 2. Enable the Google Drive API for your project
# 3. Go to "APIs & Services" > "Credentials" and create a Service Account
# 4. Download the JSON credentials for the service account
# 5. Share your portfolio folder with the service account email (found in JSON)
# 6. Copy the values below from your JSON credentials
#
# Required setup steps:
# - Create Google Cloud project
# - Enable Google Drive API
# - Create Service Account and download JSON
# - Share portfolio folder with service account email
# =============================================================================

# Service Account Email (from JSON: "client_email")
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Private Key (from JSON: "private_key")
# Note: Replace actual newlines with \n in the env variable
# e.g., -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Drive Folder ID
# Get this from the folder URL: https://drive.google.com/drive/folders/[FOLDER_ID]
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# =============================================================================
# Optional: Cache Settings
# =============================================================================

# Cache duration in seconds (default: 86400 = 24 hours)
# GOOGLE_CACHE_TTL=86400

# =============================================================================
# WhatsApp Integration
# =============================================================================

# WhatsApp phone number in international format (without +)
# Example: 243812345678 for DRC (+243)
# Format: https://wa.me/{phone}?text={message}
NEXT_PUBLIC_WHATSAPP_PHONE=your_whatsapp_number_here